# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# Sandbox/test values only. These are not production secrets.
#
# ── How to generate each secret ───────────────────────────────────────────────
# Token PIN / admin password: choose strong values, e.g.
#   openssl rand -base64 18
#
# Security Server API keys (created against each RUNNING Security Server):
#   bring the sandbox up first (scripts/install.sh), then:
#   sandboxes/timor-leste/tools/scripts/generate-ss-api-keys.sh
# ──────────────────────────────────────────────────────────────────────────────

# Security Server admin (sandbox defaults)
XROAD_ADMIN_USER=xrd
XROAD_ADMIN_PASSWORD=secret
XROAD_TOKEN_PIN=Sandbox_2026

# xrdsst provisioning (see sandboxes/timor-leste/xrdsst-config.yaml)
XRDSST_ADMIN=xrd:secret
TOKEN_PIN=Sandbox_2026
SS_MJ_API_KEY=
SS_SERVE_API_KEY=
SS_MTC_API_KEY=
SS_OSS_API_KEY=
